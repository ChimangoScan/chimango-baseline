# Large / intermediate data lives outside git.
# The reports SQLite (bl_snap.db, 10.3 GB) is NOT committed; it is published as
# a GitHub release asset and fetched by `./reproduce.sh dataset`. The committed
# sample (data/random_sample.jsonl) is the canonical draw and the small analysis
# outputs under analysis/ are kept on purpose.
*.db
data/*.db
data/*.csv
data/large_*.jsonl
data/large_*.json
*.tar
*.tar.*
*.zst
# locally generated figures (regenerated by analysis/make_figs.py)
figures/*.pdf

# python
__pycache__/
*.pyc
.venv/

# latex build
*.aux
*.log
*.out
*.bbl
*.blg
*.synctex.gz
